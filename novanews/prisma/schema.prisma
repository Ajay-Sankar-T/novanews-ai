generator client {
  provider = "prisma-client-js"

}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model SavedArticle {
  id          String   @id @default(cuid())
  title       String
  description String?
  source      String?
  url         String   @unique
  imageUrl    String?
  category    String?
  aiSummary   String?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
}